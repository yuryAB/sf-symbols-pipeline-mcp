{
  "name": "sf-symbols-pipeline-mcp",
  "version": "0.1.0",
  "description": "MCP server for custom SF Symbols pipeline validation and artifact generation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./cli": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "mcpName": "io.github.yuryAB/sf-symbols-pipeline",
  "bin": {
    "sf-symbols-pipeline-mcp": "./dist/index.js"
  },
  "author": {
    "name": "yuryAB",
    "url": "https://github.com/yuryAB"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yuryAB/sf-symbols-pipeline-mcp.git"
  },
  "homepage": "https://github.com/yuryAB/sf-symbols-pipeline-mcp#readme",
  "bugs": {
    "url": "https://github.com/yuryAB/sf-symbols-pipeline-mcp/issues"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sf-symbols",
    "custom-symbols",
    "apple",
    "ios",
    "xcode",
    "svg",
    "vector-editor",
    "swiftui"
  ],
  "files": [
    "assets",
    "dist",
    "docs",
    "examples",
    "plugins/codex",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc && npm run check:bin",
    "check:bin": "node scripts/check-bin.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
